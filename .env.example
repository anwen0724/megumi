# Megumi optional environment variables
# 复制此文件为 .env 并按需填写。不要提交 .env。

# Megumi Home 路径（可选，默认使用用户目录下的 .megumi）
# Windows 示例：%USERPROFILE%\.megumi
MEGUMI_HOME=

# Provider API Keys（可选）
# 也可以在应用 Settings -> Models 里配置，或在 ~/.megumi/settings.json 中配置。
DEEPSEEK_API_KEY=<your-deepseek-api-key>

# OpenAI
OPENAI_API_KEY=<your-openai-api-key>

# Anthropic
ANTHROPIC_API_KEY=<your-anthropic-api-key>
