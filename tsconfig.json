{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true,
    "baseUrl": ".",
    "paths": {
      "@megumi/desktop/*": ["apps/desktop/src/*"],
      "@megumi/agent": ["packages/agent/index.ts"],
      "@megumi/agent/*": ["packages/agent/*"],
      "@megumi/coding-agent": ["packages/coding-agent/index.ts"],
      "@megumi/coding-agent/*": ["packages/coding-agent/*"],
      "@megumi/ai": ["packages/ai/index.ts"],
      "@megumi/ai/*": ["packages/ai/*"],
      "@megumi/command": ["packages/command/index.ts"],
      "@megumi/command/*": ["packages/command/*"],
      "@megumi/input": ["packages/input/index.ts"],
      "@megumi/input/*": ["packages/input/*"],
      "@megumi/shared": ["packages/shared/index.ts"],
      "@megumi/shared/*": ["packages/shared/*"]
    }
  },
  "include": ["apps/**/*", "packages/**/*", "tests/**/*"],
  "exclude": ["node_modules"]
}
